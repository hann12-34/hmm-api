PORT=3001

# Home Micro Maintenance 전용 MongoDB Atlas URI
# Discovr DB/계정 사용 금지!
#
# Atlas에서 받는 법:
# 1. https://cloud.mongodb.com 로그인
# 2. HMM용 Cluster 선택 (또는 새 Cluster)
# 3. Connect → Drivers → connection string 복사
# 4. <password>를 실제 비밀번호로 바꾸기
# 5. DB 이름을 hmm_maintenance 로 지정 (기존 DB 이름 건드리지 않음)
#
# 예시 형식:
# MONGODB_URI=mongodb+srv://HMM_USER:HMM_PASSWORD@cluster.xxxxx.mongodb.net/hmm_maintenance?retryWrites=true&w=majority

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/hmm_maintenance?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=*

# Optional notifications (logs only if unset)
# RESEND_API_KEY=re_xxxx
# NOTIFY_FROM_EMAIL=HMM <notify@yourdomain.com>
# NOTIFY_ADMIN_EMAIL=admin@yourdomain.com
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
